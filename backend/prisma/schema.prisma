generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Image {
  id           String   @id @default(uuid())
  originalName String
  storageUrl   String?
  format       String
  width        Int?
  height       Int?
  size         Int
  status       String   @default("PENDING")
  reason       String?
  createdAt    DateTime @default(now())
}